# ─────────────────────────────────────────────────────────────────────────────
# CSI Digital Operating Platform — local development environment
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# In staging/production all secrets come from Kubernetes Secrets / Vault (SAD §12).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: point directly at PostgreSQL 16 (port 5432).
# Staging/prod: point at PgBouncer (port 6432, transaction mode).
DATABASE_URL=postgresql://csidop_app:CHANGE_ME@localhost:5432/csidop

# ── Redis (sessions + Celery broker) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OIDC / Auth (Microsoft Entra ID or Google Workspace) ─────────────────────
# For Entra ID: https://login.microsoftonline.com/{tenant-id}/v2.0
# For Google:   https://accounts.google.com
OIDC_PROVIDER_URL=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ── Session ───────────────────────────────────────────────────────────────────
# Min 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-at-least-32-character-random-secret

# ── FastAPI compute worker ────────────────────────────────────────────────────
# Local dev: http://localhost:8001
# In-cluster: http://fastapi-worker:8001 (K8s service DNS, SAD §16.2)
FASTAPI_WORKER_URL=http://localhost:8001

# ── Public (exposed to browser) ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
